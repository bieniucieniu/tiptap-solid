{
  "name": "@tiptap-solid/lib",
  "version": "0.0.1",
  "private": true,
  "description": "SolidJS components for tiptap (library source)",
  "files": [
    "src",
    "dist",
    "vite.config.mjs",
    "tsconfig.json"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./menus": {
      "types": "./dist/menus/index.d.ts",
      "import": "./dist/menus/index.js",
      "default": "./dist/menus/index.js"
    },
    "./node-view": {
      "types": "./dist/node-view.d.ts",
      "import": "./dist/node-view.js",
      "default": "./dist/node-view.js"
    }
  },
  "scripts": {
    "build": "vp pack"
  },
  "dependencies": {
    "fast-equals": "^5.3.3"
  },
  "devDependencies": {
    "@tiptap/core": "^3.23.5",
    "@tiptap/pm": "^3.23.5",
    "solid-js": "^1.9.0",
    "unplugin-solid": "^1.0.0",
    "unrun": "latest",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@tiptap/core": "^3.23.5",
    "@tiptap/pm": "^3.23.5",
    "solid-js": "^1.9.0"
  },
  "optionalDependencies": {
    "@tiptap/extension-bubble-menu": "^3.23.5",
    "@tiptap/extension-floating-menu": "^3.23.5"
  }
}
