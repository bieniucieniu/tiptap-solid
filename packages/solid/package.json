{
  "name": "@tiptap-solid/lib",
  "version": "0.0.1",
  "private": true,
  "description": "SolidJS components for tiptap (library source)",
  "files": [
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
