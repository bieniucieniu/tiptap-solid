      "import": "./src/node-view.ts",
      "default": "./src/node-view.ts"
    }
  },
  "dependencies": {
    "fast-equals": "^5.3.3"
  },
  "peerDependencies": {
    "@tiptap/core": "^3.23.5",
    "@tiptap/pm": "^3.23.5",
    "solid-js": "^1.9.0"
  },
  "optionalDependencies": {
    "@tiptap/extension-bubble-menu": "^3.23.5",
    "@tiptap/extension-floating-menu": "^3.23.5"
