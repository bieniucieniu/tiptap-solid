{
  "name": "tiptap-solid",
  "version": "0.0.1",
  "description": "SolidJS components for tiptap",
  "keywords": [
    "tiptap",
    "tiptap solid components"
  ],
  "homepage": "https://tiptap.dev",
  "license": "MIT",
  "files": [
    "packages/solid/src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./packages/solid/src/index.ts",
      "import": "./packages/solid/src/index.ts",
      "default": "./packages/solid/src/index.ts"
    },
    "./menus": {
      "types": "./packages/solid/src/menus/index.ts",
      "import": "./packages/solid/src/menus/index.ts",
      "default": "./packages/solid/src/menus/index.ts"
    },
    "./node-view": {
      "types": "./packages/solid/src/node-view.ts",
      "import": "./packages/solid/src/node-view.ts",
      "default": "./packages/solid/src/node-view.ts"
    }
  },
  "dependencies": {
    "fast-equals": "^5.3.3"
  },
  "devDependencies": {
    "vite": "^8.0.16",
    "vite-plus": "^0.1.24"
  },
  "peerDependencies": {
    "@tiptap/core": "^3.23.5",
    "@tiptap/pm": "^3.23.5",
    "solid-js": "^1.9.0"
  },
  "optionalDependencies": {
    "@tiptap/extension-bubble-menu": "^3.23.5",
    "@tiptap/extension-floating-menu": "^3.23.5"
  }
}
